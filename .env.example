# Kokoro runs on alpha-old (Tailscale). Override if needed.
KOKORO_BASE_URL=http://100.89.61.7:8880/v1

# Google Gemini API key, used to OCR uploaded page images into text.
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# Tailscale auth key for tsdproxy (reuse your tailnet reusable key).
TSDPROXY_AUTHKEY=
